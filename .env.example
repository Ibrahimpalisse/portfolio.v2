# =============================================================================
# Variables d'environnement — portfolio Vignes Ibrahim
# Copiez ce fichier en .env.local et remplissez les valeurs.
# Ne commitez JAMAIS .env.local (déjà dans .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL
# URL publique du site, avec https, sans slash final.
# Utilisé pour : SEO, sitemap, robots.txt, balises Open Graph, liens canoniques.
#
# Exemples :
#   En local (optionnel) : http://localhost:3000
#   En production        : https://zishi.dev
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://zishi.dev

# -----------------------------------------------------------------------------
# RESEND_API_KEY
# Clé secrète Resend — serveur uniquement, ne jamais exposer côté client.
#
# Où l'obtenir :
#   1. Compte sur https://resend.com
#   2. API Keys → Create API Key (permission « Sending access »)
#   3. Copiez la clé (commence par re_)
#
# Exemple : RESEND_API_KEY=re_xxxxxxxxxxxx
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# RESEND_FROM_EMAIL
# Adresse d'envoi — doit être sur un domaine vérifié dans Resend.
# Format recommandé : "Nom <email@domaine.com>"
#
# Configuration Resend :
#   1. Domains → Add Domain → zishi.dev (ou votre domaine)
#   2. Ajoutez les enregistrements DNS (SPF, DKIM)
#   3. Attendez la vérification
#
# En dev/test sans domaine vérifié, utilisez onboarding@resend.dev
# (envoi limité à votre adresse de compte Resend).
#
# Exemple : RESEND_FROM_EMAIL=Portfolio Zishi <noreply@zishi.dev>
# -----------------------------------------------------------------------------
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# RESEND_NOTIFY_EMAIL
# Adresse qui reçoit les notifications (contact + avis).
# Par défaut : contact@zishi.dev (voir src/lib/brand.ts) si vide.
#
# Exemple : RESEND_NOTIFY_EMAIL=contact@zishi.dev
# -----------------------------------------------------------------------------
RESEND_NOTIFY_EMAIL=

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_TURNSTILE_SITE_KEY  (clé publique — visible côté navigateur)
# TURNSTILE_SECRET_KEY            (clé secrète — serveur uniquement, ne jamais exposer)
#
# Anti-spam Cloudflare Turnstile sur les formulaires contact et avis.
# Où les obtenir : https://dash.cloudflare.com → Turnstile → Add site
#   - Domaines : zishi.dev + localhost (pour le dev)
#   - Widget mode : Managed (recommandé)
#
# Clés de TEST (toujours valides, pour dev local uniquement) :
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
#
# En production : utilisez les vraies clés générées par Cloudflare.
# En production, Turnstile est OBLIGATOIRE par défaut (FORM_REQUIRE_TURNSTILE).
# Pour le dev local sans Turnstile : FORM_REQUIRE_TURNSTILE=false
# Si vous laissez vide en dev : Turnstile est désactivé (formulaires fonctionnent quand même).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# FORM_REQUIRE_TURNSTILE
# true  = Turnstile obligatoire (défaut en production)
# false = désactive l'obligation (dev/staging uniquement)
# -----------------------------------------------------------------------------
# FORM_REQUIRE_TURNSTILE=false

# -----------------------------------------------------------------------------
# FORM_ALLOWED_ORIGINS
# Origines supplémentaires autorisées pour POST /api/contact et /api/review
# (preview Vercel, staging…). Séparez par des virgules.
#
# Exemple : FORM_ALLOWED_ORIGINS=https://portfolio-git-main.vercel.app
# -----------------------------------------------------------------------------
# FORM_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# SUPABASE — Authentification admin
# NEXT_PUBLIC_SUPABASE_URL      URL du projet (Settings → API)
# NEXT_PUBLIC_SUPABASE_ANON_KEY Clé anon publique (safe côté client)
#
# Ne commitez JAMAIS la service_role key.
# Créez un utilisateur : Authentication → Users → Add user
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — SERVEUR UNIQUEMENT (jamais NEXT_PUBLIC_, jamais côté client).
# Requis pour l'inbox contact + modération avis + stats À propos + projets
# (contact_messages, reviews, about_stats, projects, site_social_links + Storage portfolio-projects).
# Supabase → Settings → API → service_role (secret)
# SUPABASE_SERVICE_ROLE_KEY=

# Après la clé service_role + DATABASE_URL :
#   npm run db:migrate
# (crée contact_messages, reviews, about_stats, projects, site_social_links + bucket portfolio-projects)

# -----------------------------------------------------------------------------
# DATABASE_URL — Postgres Supabase (système de migrations)
# Serveur UNIQUEMENT — ne jamais préfixer avec NEXT_PUBLIC_
#
# Où la trouver :
#   Supabase → Project Settings → Database → Connection string → URI
#   Mode recommandé pour migrations : "Session" ou "Direct"
#   (évitez le pooler Transaction pour les DDL / migrations).
#
# Format :
#   postgresql://postgres.[PROJECT-REF]:[MOT_DE_PASSE]@aws-0-xx.pooler.supabase.com:5432/postgres
#   ou direct :
#   postgresql://postgres:[MOT_DE_PASSE]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Si le mot de passe contient @ # % etc., encode-le (URL-encoding).
#
# Commandes :
#   npm run db:status   — état pending / applied
#   npm run db:migrate  — applique supabase/migrations/*.sql
#   npm run db:new -- nom_migration  — crée un nouveau fichier SQL
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# ADMIN_ALLOWED_EMAILS
# Liste blanche des emails autorisés à accéder à /admin (séparés par des virgules).
# Même si un compte Supabase existe, seuls ces emails peuvent se connecter.
#
# Exemple : ADMIN_ALLOWED_EMAILS=contact@zishi.dev
#
# MFA TOTP (obligatoire pour l'admin) :
#   1. Supabase → Authentication → Providers → activer Email
#   2. Authentication → MFA → activer TOTP
#   3. Créez l'utilisateur admin (Users → Add user)
#   4. Enrôlez le TOTP pour cet utilisateur (Authentication → Users → MFA)
#   5. Connexion : /admin/connexion (mot de passe puis code 6 chiffres)
# -----------------------------------------------------------------------------
ADMIN_ALLOWED_EMAILS=
